{
  "name": "claude-advanced-testing",
  "version": "1.0.0",
  "description": "MCP server providing Claude with advanced testing tools powered by Playwright",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-advanced-testing": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "lint": "eslint src/",
    "postinstall": "playwright install chromium"
  },
  "keywords": [
    "mcp",
    "claude",
    "playwright",
    "testing",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.52.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
